model CategoryGroup {
  id         String     @id @default(uuid())
  userId     String
  name       String
  position   Int
  categories Category[]

  // missing reference to user

// add kind categorygroupking

// this needs testing
    // @@unique([userId, name])
}

model Category {
  // TODO: Each subcategory will need a due date/reoccurance etc
  // TODO: overspent
  // Snooze target for month
  id              String        @id @default(uuid())
  userId          String
  categoryGroupId String
  // budgetId     String
  name            String
  position        Int
  // budget       Budget        @relation(fields: [budgetId], references: [id])
  transactions    Transaction[]
  categoryGroup   CategoryGroup @relation(fields: [categoryGroupId], references: [id], onDelete: Cascade)
  months          Month[]
  payees          Payee[]       @relation("PayeeDefaultCategory")


// this needs testing
    // @@unique([userId, name])
}

model Month {
  id         String   @id @default(uuid())
  categoryId String
  month      DateTime
  activity   Decimal  @default(0)
  assigned   Decimal  @default(0)
  available  Decimal  @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, month])
}

model MonthMemo {
  id      String   @id @default(uuid())
  userId  String
  month   DateTime
  content String   @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
}

enum CategoryType {
  EXPENSE
  INCOME
}

model Account {
  id           String        @id @default(uuid())
  position     Int           
  userId       String
  name         String
  open         Boolean       @default(true)
  deletable    Boolean?       @default(false)
  type         AccountType
  balance      Decimal       @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
    
  // User can have same name per type
  @@unique([userId, type, name])
  // User cannot have same type and position
  @@unique([userId, type, position])
}

enum AccountType {
  BANK
  CREDIT_CARD
}

enum TransactionOrigin {
  USER
  SYSTEM
}

model Transaction {
  id             String   @id @default(uuid())
  accountId      String
   // TODO:(lewis 2026-02-09 10:13) category should always be a string because even is unasigned it has a category
  categoryId     String?
  payeeId        String?
  // budgetId    String
  date           DateTime @default(now())
  inflow         Decimal  @default(0)
  outflow        Decimal  @default(0)
  // used for managing account.deletable 
  origin      TransactionOrigin? @default(USER) 

  // transfer transaction between accounts
  transferAccountId     String?
  transferTransactionId String?      @unique
  transferTransaction   Transaction? @relation("TransferPair", fields: [transferTransactionId], references: [id], onDelete: Cascade)
  pairedTransaction     Transaction? @relation("TransferPair")


 // TODO:(lewis 2026-02-09 10:15) i think this should be "" by default
  memo         String?
  cleared      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  account      Account       @relation(fields: [accountId], references: [id])
  category     Category?     @relation(fields: [categoryId], references: [id])
  payee        Payee?        @relation(fields: [payeeId], references: [id])
  // budget      Budget      @relation(fields: [budgetId], references: [id])
}

enum PayeeOrigin {
  USER
  SYSTEM
}

model Payee {
  id                           String   @id @default(uuid())
  userId                       String
  name                         String
  origin                       PayeeOrigin? @default(USER) 
  defaultCategoryId            String?
  includeInPayeeList           Boolean  @default(true)
  automaticallyCategorisePayee Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultCategory Category?     @relation("PayeeDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  transactions    Transaction[]

  @@unique([userId, name])
}
